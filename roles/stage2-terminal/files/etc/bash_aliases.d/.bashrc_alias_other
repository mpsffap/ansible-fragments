#!/bin/bash

# shellcheck disable=SC2139,SC2015,SC2142,SC2154

# ps stuff
alias pmon='ps -aux --sort=-%mem | head'  # Show top memory-consuming processes

# apparmor
alias aa='sudo aa-status'
alias aa-enforce-all='sudo aa-enforce /etc/apparmor.d/*'
alias aa-complain-all='sudo aa-complain /etc/apparmor.d/*'

# systemctl
alias sdr='systemctl daemon-reload'
alias syss='systemctl status'
alias sysup='systemctl start'
alias sysdown='systemctl stop'
alias sysre='systemctl restart'

# xset keyboard rate
alias xx='xset r rate 250 50'

# say something with espeak
alias cowsay-en='cowsay $(fortune)'
alias cowsay-de='cowsay $(fortune de)'
alias cowsay-off='cowsay $(fortune de -o)'
alias cowsay-bofh='cowsay $(fortune bofh-excuses)'
alias cowsay-anarchy='cowsay $(fortune anarchism)'
alias say-en='say "$(fortune)"'
alias say-de='say "$(fortune de)"'
alias say-off='say "$(fortune de -o)"'
alias say-off='say "$(fortune de -o)"'
alias say-bofh='say "$(fortune bofh-excuses)"'
alias say-anarchy='say "$(fortune anarchism)"'
say(){
    SAYING="$1"
    echo "$SAYING"
    dunst_espeak.bash SAY "$SAYING"
}
