#!/bin/bash

# shellcheck disable=SC2139,SC2015,SC2142,SC2154

# Custom config aliases
alias cfg-vim="edit ~/.vimrc"
alias cfg-nvim="edit ~/.config/nvim/init.lua"
alias cfg-qtile="edit ~/.config/qtile/screens.py"
alias cfg-kitty="edit ~/.config/kitty/kitty.conf"
alias cfg-tmux="edit ~/.config/tmux/tmux.conf.local"
alias cfg-bashrc="edit ~/.bashrc && source ~/.bashrc"
alias cfg-alias-common="edit /etc/bash_aliases/ && source ~/.bashrc"
alias cfg-alias-custom="edit ~/.config/bashrc/.bashrc_alias_custom && source ~/.config/bashrc/.bashrc_alias_custom"
alias cfg-ssh="edit ~/.ssh/config"
alias cfg-hosts="sudo edit /etc/hosts"
alias cfg-fstab="sudo edit /etc/fstab"
alias cfg-crypt="sudo edit /etc/crypttab"
alias cfg-net="sudo edit /etc/network/interfaces"
alias cfg-apt='sudo edit /etc/apt/sources.list'
