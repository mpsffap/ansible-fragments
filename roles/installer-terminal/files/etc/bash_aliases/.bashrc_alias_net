#!/bin/bash

# shellcheck disable=SC2139,SC2015,SC2142,SC2154

# Alias config: netstat
alias ns='sudo netstat -tulpn | head -n 2 ; sudo netstat -tulpn | tail -n +3 | sort -k 4'
alias nsao='sudo netstat -tulpano | head -n 2 ; sudo netstat -tulpano | tail -n +3 | sort -k 4'
alias ports='lsof -i -P -n'

# Alias config: iptables
alias siptl='sudo iptables -L -v -n'
alias siptln='sudo iptables -L -v -n -t nat'

# bridging
alias sbs='sudo brctl show'

# routing
alias srn='sudo route -n'

# ifconfig
alias sif='sudo ifconfig'
alias sifa='sudo ifconfig -a'

# public ip
alias whoamip='echo $(curl -s ifconfig.me)'

