#!/bin/bash

# shellcheck disable=SC2139,SC2015,SC2142,SC2154

# Custom config aliases
alias cfg-vim="vim ~/.vimrc"
alias cfg-nvim="vim ~/.config/nvim/init.lua"
alias cfg-ssh="vim ~/.ssh/config"
alias cfg-hosts="sudo vim /etc/hosts"
alias cfg-fstab="sudo vim /etc/fstab"
alias cfg-crypt="sudo vim /etc/crypttab"
alias cfg-aptsrc='sudo vim /etc/apt/sources.list'
alias cfg-net="sudo vim /etc/network/interfaces"
alias cfg-kitty="vim ~/.config/kitty/kitty.conf"
alias cfg-tmux="vim ~/.config/tmux/tmux.conf.local"
alias cfg-bashrc="vim ~/.bashrc && source ~/.bashrc"
alias cfg-alias-common="vim /etc/bash_aliases/ && source ~/.bashrc"
alias cfg-alias-custom="vim ~/.config/bashrc/.bashrc_alias_custom && source ~/.config/bashrc/.bashrc_alias_custom"

